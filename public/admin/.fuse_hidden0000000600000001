  const data = kw
    ? allLeaveRecords.filter(r =>
        (r.employee_name || '').toLowerCase().includes(kw) ||
        (r.employee_code || '').toLowerCase().includes(kw)
      )
    : allLeaveRecords;

  // Update summary
  document.getElementById('lr-total').textContent    = data.length;
  document.getElementById('lr-pending').textContent  = data.filter(r => r.status === 'pending').length;
  document.getElementById('lr-approved').textContent = data.filter(r => r.status === 'approved').length;
  document.getElementById('lr-rejected').textContent = data.filter(r => r.status === 'rejected').length;
  document.getElementById('lr-days').textContent     = data.filter(r => r.status === 'approved').reduce((s,r) => s + (r.total_days||0), 0);

