async function saveEmployee() {
  const name = document.getElementById('f-name').value.trim();
  const code = document.getElementById('f-code').value.trim().toUpperCase();
  if (!name) return toast('กรุณาระบุชื่อพนักงาน', 'error');
  if (!editingId && !code.match(/^TK\d+$/)) return toast('รหัสต้องเป็น TK001 เป็นต้นไป', 'error');

  const body = {
    employee_code: code, name,
    sex: document.getElementById('f-sex').value || null,
    phone_no: document.getElementById('f-phone').value || null,
    email: document.getElementById('f-email').value || null,
    department_id: document.getElementById('f-dept').value ? parseInt(document.getElementById('f-dept').value) : null,
    role: document.getElementById('f-role').value,
    manager_id: document.getElementById('f-manager').value ? parseInt(document.getElementById('f-manager').value) : null,
  };

  try {
    const url = editingId ? `${API}/api/employee/${editingId}` : `${API}/api/employee/`;
    const method = editingId ? 'PUT' : 'POST';
    const res = await fetch(url, { method, headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'เกิดข้อผิดพลาด');
    toast(editingId ? 'แก้ไขข้อมูลเรียบร้อย' : 'เพิ่มพนักงานสำเร็จ');
    closeModal('emp-modal');
    loadEmployees();
  } catch (err) { toast(err.message, 'error'); }
}

async function confirmDelete(id, name) {
  if (!confirm(`ยืนยันการลบพนักงาน "${name}" ?\n(ข้อมูลจะถูก deactivate ไม่ถูกลบถาวร)`)) return;
  try {
    const res = await fetch(`${API}/api/employee/${id}`, { method: 'DELETE' });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error);
    toast(`ลบ ${name} เรียบร้อย`);
    loadEmployees();
  } catch (err) { toast(err.message, 'error'); }
}

// ---- DEPARTMENTS ----
let allDeptData = [];  // เก็บข้อมูล dept ล่าสุดจาก API

async function loadDepartments() {
  try {
    const res = await fetch(`${API}/api/department`);
    if (!res.ok) throw new Error(`HTTP ${res.status}: ${res.statusText}`);
    const json = await res.json();
    allDeptData = Array.isArray(json) ? json : (json.departments || json.data || []);
    allDepts = allDeptData.map(d => ({ id: d.id, name: d.name }));
    updateDeptStats(allDeptData);
    renderDeptTable(allDeptData);
  } catch(err) {
    document.getElementById('dept-tbody').innerHTML = `<tr><td colspan="6" class="no-data" style="color:#ef4444;">ไม่สามารถโหลดข้อมูล: ${err.message}<br><small>กรุณา restart server แล้วลองใหม่</small></td></tr>`;
  }
}

function updateDeptStats(data) {
  document.getElementById('ds-total').textContent  = data.length;
  document.getElementById('ds-emp').textContent    = data.reduce((s, d) => s + parseInt(d.employee_count || 0), 0);
  document.getElementById('ds-active').textContent = data.filter(d => parseInt(d.employee_count || 0) > 0).length;
}

function renderDeptTable(data) {
  const tbody = document.getElementById('dept-tbody');
  if (!data.length) { tbody.innerHTML = '<tr><td colspan="6" class="no-data">ยังไม่มีแผนก</td></tr>'; return; }
  tbody.innerHTML = data.map(d => {
    const cnt = parseInt(d.employee_count || 0);
    const statusBadge = d.is_active
      ? '<span class="badge badge-employee">ใช้งาน</span>'
      : '<span class="badge" style="background:#f3f4f6;color:#6b7280;">ปิดใช้งาน</span>';
    return `<tr>
      <td style="color:#9ca3af;font-size:12px;">${d.id}</td>
      <td>
        <strong>${d.name}</strong>
        ${cnt > 0 ? `<span style="margin-left:6px;color:#9ca3af;font-size:11px;">(${cnt} คน)</span>` : ''}
      </td>
      <td style="font-size:12px;color:#6b7280;">${d.description || '<span style="color:#d1d5db;">—</span>'}</td>
      <td>
        ${cnt > 0
          ? `<button class="btn btn-ghost btn-sm" onclick="viewDeptDetail(${d.id}, '${d.name.replace(/'/g,"\\'")}')">👥 ${cnt} คน</button>`
          : '<span style="color:#d1d5db;font-size:12px;">ยังไม่มีพนักงาน</span>'}
      </td>
      <td>${statusBadge}</td>
      <td><div class="actions">
        <button class="btn btn-ghost btn-sm" onclick="openEditDeptModal(${d.id})">แก้ไข</button>
        <button class="btn btn-danger btn-sm" onclick="confirmDeleteDept(${d.id}, '${d.name.replace(/'/g,"\\'")}', ${cnt})">ลบ</button>
      </div></td>
    </tr>`;
  }).join('');
}

function filterDepartments() {
  const kw = document.getElementById('dept-search').value.toLowerCase();
  const filtered = kw
    ? allDeptData.filter(d => d.name.toLowerCase().includes(kw) || (d.description || '').toLowerCase().includes(kw))
    : allDeptData;
  renderDeptTable(filtered);
}

function openDeptModal() {
  document.getElementById('dept-modal-title').textContent = 'เพิ่มแผนกใหม่';
  document.getElementById('d-edit-id').value  = '';
  document.getElementById('d-name').value     = '';
  document.getElementById('d-description').value = '';
  openModal('dept-modal');
}

function openEditDeptModal(id) {
  const dept = allDeptData.find(d => d.id === id);
  if (!dept) return;
  document.getElementById('dept-modal-title').textContent = `แก้ไขแผนก — ${dept.name}`;
  document.getElementById('d-edit-id').value     = dept.id;
  document.getElementById('d-name').value        = dept.name;
  document.getElementById('d-description').value = dept.description || '';
  openModal('dept-modal');
}

async function saveDepartment() {
  const editId = document.getElementById('d-edit-id').value;
  const name   = document.getElementById('d-name').value.trim();
  const desc   = document.getElementById('d-description').value.trim();
  if (!name) return toast('กรุณาระบุชื่อแผนก', 'error');

  try {
    const isEdit = !!editId;
    const url    = isEdit ? `${API}/api/department/${editId}` : `${API}/api/department`;
    const method = isEdit ? 'PUT' : 'POST';
    const res = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, description: desc || null }),
    });
    const data = await res.json();
    if (!res.ok || data.success === false) throw new Error(data.error || 'เกิดข้อผิดพลาด');
    toast(data.message || (isEdit ? 'แก้ไขแผนกสำเร็จ' : 'เพิ่มแผนกสำเร็จ'));
    closeModal('dept-modal');
    await loadDepartments();
    populateDeptModalSelect(); // refresh dropdown ใน employee modal
  } catch(err) { toast(err.message, 'error'); }
}

async function confirmDeleteDept(id, name, empCount) {
  if (empCount > 0) {
    toast(`ไม่สามารถลบได้ เพราะมีพนักงาน ${empCount} คนอยู่ในแผนกนี้`, 'error');
    return;
  }
  if (!confirm(`ยืนยันลบแผนก "${name}" ?\nการลบจะเป็นแบบ soft delete`)) return;
  try {
    const res = await fetch(`${API}/api/department/${id}`, { method: 'DELETE' });
    const data = await res.json();
    if (!res.ok || data.success === false) throw new Error(data.error || 'เกิดข้อผิดพลาด');
    toast(data.message || 'ลบแผนกสำเร็จ');
    closeDeptDetail();
    loadDepartments();
  } catch(err) { toast(err.message, 'error'); }
}

