// ---- Modal ----
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
function openModal(id)  { document.getElementById(id).classList.add('open'); }

// ---- EMPLOYEES ----
async function loadEmployees() {
  const res = await fetch(`${API}/api/employee/`);
  allEmployees = await res.json();
  renderTable(allEmployees);
  updateStats(allEmployees);
  populateDeptFilter();
  populateManagerSelect();
}

function updateStats(emps) {
  document.getElementById('stat-total').textContent = emps.length;
  document.getElementById('stat-admin').textContent = emps.filter(e => e.role === 'admin' || e.role === 'hr').length;
  document.getElementById('stat-line').textContent = emps.filter(e => e.line_user_id).length;
  const depts = new Set(emps.map(e => e.department_id).filter(Boolean));
  document.getElementById('stat-dept').textContent = depts.size;
}

function populateDeptFilter() {
  const sel = document.getElementById('dept-filter');
  const existing = new Set([...sel.options].map(o => o.value));
  const seen = new Set();
  allEmployees.forEach(e => {
    if (e.department_id && !seen.has(e.department_id)) {
      seen.add(e.department_id);
      if (!existing.has(String(e.department_id))) {
        const opt = document.createElement('option');
        opt.value = e.department_id; opt.textContent = e.department_name || `Dept ${e.department_id}`;
        sel.appendChild(opt);
      }
    }
  });
}

function populateManagerSelect() {
  const sel = document.getElementById('f-manager');
  sel.innerHTML = '<option value="">— ไม่มี —</option>';
  allEmployees.filter(e => e.role === 'manager' || e.role === 'admin').forEach(e => {
    const opt = document.createElement('option');
    opt.value = e.id; opt.textContent = `${e.name} (${e.employee_code})`;
    sel.appendChild(opt);
  });
}

function roleBadge(role) {
  const map = { admin:'badge-admin', hr:'badge-hr', manager:'badge-manager', employee:'badge-employee' };
  return `<span class="badge ${map[role] || ''}">${role}</span>`;
}

function renderTable(data) {
  const tbody = document.getElementById('emp-tbody');
  if (!data.length) { tbody.innerHTML = '<tr><td colspan="8" class="no-data">ไม่พบข้อมูล</td></tr>'; return; }
  tbody.innerHTML = data.map(e => {
    const initials = e.name ? e.name.trim().split(' ').map(w => w[0]).slice(0,2).join('').toUpperCase() : '?';
    const lineStatus = e.line_user_id
      ? '<span style="color:#22c55e;font-size:18px;">●</span>'
      : '<span style="color:#d1d5db;font-size:18px;">○</span>';
    return `<tr>
      <td><div class="emp-info">
        <div class="emp-avatar">${initials}</div>
        <div><div class="emp-name">${e.name}</div><div class="emp-code">${e.employee_code}</div></div>
      </div></td>
      <td><span class="badge ${e.sex==='M'?'badge-m':'badge-w'}">${e.sex==='M'?'ชาย':'หญิง'}</span></td>
      <td>${e.department_name || '—'}</td>
      <td>${roleBadge(e.role)}</td>
      <td>${e.phone_no || '—'}</td>
      <td style="font-size:12px;">${e.email || '—'}</td>
      <td style="text-align:center;">${lineStatus}</td>
      <td><div class="actions">
        <button class="btn btn-ghost btn-sm" onclick="openEditModal(${e.id})">แก้ไข</button>
        <button class="btn btn-danger btn-sm" onclick="confirmDelete(${e.id}, '${e.name}')">ลบ</button>
      </div></td>
    </tr>`;
  }).join('');
}

function filterTable() {
  const kw = document.getElementById('search-input').value.toLowerCase();
  const dept = document.getElementById('dept-filter').value;
  const role = document.getElementById('role-filter').value;
  const filtered = allEmployees.filter(e =>
    (!kw || e.name.toLowerCase().includes(kw) || e.employee_code.toLowerCase().includes(kw)) &&
    (!dept || String(e.department_id) === dept) &&
    (!role || e.role === role)
  );
  renderTable(filtered);
}

function openAddModal() {
  editingId = null;
  document.getElementById('modal-title').textContent = 'เพิ่มพนักงานใหม่';
  ['f-code','f-name','f-phone','f-email'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('f-sex').value = '';
  document.getElementById('f-role').value = 'employee';
  document.getElementById('f-dept').value = '';
  document.getElementById('f-manager').value = '';
  document.getElementById('f-code').disabled = false;
  populateDeptModalSelect();
  openModal('emp-modal');
}

function populateDeptModalSelect() {
  const sel = document.getElementById('f-dept');
  sel.innerHTML = '<option value="">— เลือกแผนก —</option>';
  allDepts.forEach(d => {
    const opt = document.createElement('option');
    opt.value = d.id; opt.textContent = d.name;
    sel.appendChild(opt);
  });
