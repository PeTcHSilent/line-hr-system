<script>
const API = '';
let allEmployees = [], allDepts = [], editingId = null;

// ---- Auth Guard ----
const _token = localStorage.getItem('adminToken');
if (!_token) { window.location.href = '/admin/login'; }

// ตรวจ token กับ server
fetch('/api/auth/verify', { method: 'POST', headers: { Authorization: `Bearer ${_token}` } })
  .then(r => { if (!r.ok) { localStorage.removeItem('adminToken'); window.location.href = '/admin/login'; } })
  .catch(() => {});

// helper สำหรับ API call ที่ต้องการ auth
function authHeaders() {
  return { 'Content-Type': 'application/json', Authorization: `Bearer ${_token}` };
}

// Logout
function logout() {
  localStorage.removeItem('adminToken');
  window.location.href = '/admin/login';
}

// Authenticated fetch wrapper — injects Authorization header on every call
function apiFetch(url, opts = {}) {
  const headers = Object.assign({}, authHeaders(), opts.headers || {});
  return fetch(url, Object.assign({}, opts, { headers }));
}

// ---- Utils ----
function toast(msg, type = 'success') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'show ' + type;
  setTimeout(() => el.className = '', 2800);
}

function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  event.currentTarget.classList.add('active');
  const titles = {
    employees:'Employee Management', departments:'Department Management',
    attendance:'Attendance', 'leave-records':'Leave Records',
    leaves:'Leave Types', holidays:'Holiday Management',
    ot:'OT Management', report:'Summary Report', calendar:'Calendar'
  };
  document.getElementById('page-title').textContent = titles[name] || name;
  if (name === 'departments') loadDepartments();
  if (name === 'attendance') initAttendance();
  if (name === 'leave-records') initLeaveRecords();
  if (name === 'leaves') loadLeaveTypes();
  if (name === 'holidays') loadHolidays();
  if (name === 'ot') initOT();
  if (name === 'report') initReport();
  if (name === 'calendar') initCalendar();
}

function updateClock() {
