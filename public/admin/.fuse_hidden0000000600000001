<!-- Main -->
<div class="main">
  <div class="topbar">
    <div class="topbar-title" id="page-title">Employee Management</div>
    <div class="topbar-right">
      <div class="topbar-dot"></div>
      <span>Server online</span>
      <span style="color:#d1d5db">|</span>
      <span id="current-time"></span>
      <span style="color:#d1d5db">|</span>
      <button onclick="logout()" style="background:none;border:1px solid #e8ecf0;border-radius:6px;padding:5px 12px;font-size:12px;color:#6b7280;cursor:pointer;display:flex;align-items:center;gap:5px;" onmouseover="this.style.background='#fee2e2';this.style.color='#dc2626'" onmouseout="this.style.background='none';this.style.color='#6b7280'">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        ออกจากระบบ
      </button>
    </div>
  </div>

  <div class="content">

    <!-- ==================== EMPLOYEES PAGE ==================== -->
    <div class="page active" id="page-employees">
      <div class="stat-grid" id="stat-grid">
        <div class="stat-card"><div class="label">พนักงานทั้งหมด</div><div class="value" id="stat-total">—</div><div class="sub">active</div></div>
        <div class="stat-card"><div class="label">Admin / HR</div><div class="value" id="stat-admin">—</div><div class="sub">คน</div></div>
        <div class="stat-card"><div class="label">เชื่อม LINE แล้ว</div><div class="value" id="stat-line">—</div><div class="sub">คน</div></div>
        <div class="stat-card"><div class="label">แผนกทั้งหมด</div><div class="value" id="stat-dept">—</div><div class="sub">แผนก</div></div>
      </div>

      <div class="card">
        <div class="card-header">
          <div class="card-title">รายชื่อพนักงาน</div>
          <div class="search-box">
            <svg width="14" height="14" fill="none" stroke="#9ca3af" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="search-input" placeholder="ค้นหาชื่อ / รหัส..." oninput="filterTable()">
          </div>
          <select class="filter" id="dept-filter" onchange="filterTable()">
            <option value="">ทุกแผนก</option>
          </select>
          <select class="filter" id="role-filter" onchange="filterTable()">
            <option value="">ทุก Role</option>
            <option value="employee">Employee</option>
            <option value="manager">Manager</option>
            <option value="hr">HR</option>
            <option value="admin">Admin</option>
          </select>
          <button class="btn btn-primary" onclick="openAddModal()">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            เพิ่มพนักงาน
          </button>
        </div>
        <div style="overflow-x:auto;">
          <table>
            <thead>
              <tr>
                <th>พนักงาน</th>
                <th>เพศ</th>
                <th>แผนก</th>
                <th>Role</th>
                <th>โทรศัพท์</th>
                <th>Email</th>
                <th>LINE</th>
                <th>จัดการ</th>
              </tr>
            </thead>
            <tbody id="emp-tbody">
              <tr><td colspan="8" class="no-data">กำลังโหลด...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ==================== DEPARTMENTS PAGE ==================== -->
    <div class="page" id="page-departments">
      <!-- Summary -->
      <div class="stat-grid" style="grid-template-columns:repeat(3,1fr);" id="dept-stat-grid">
        <div class="stat-card"><div class="label">แผนกทั้งหมด</div><div class="value" id="ds-total" style="color:#1357B0;">—</div><div class="sub">แผนก</div></div>
        <div class="stat-card"><div class="label">พนักงานทั้งหมด</div><div class="value" id="ds-emp" style="color:#22c55e;">—</div><div class="sub">คน (รวมทุกแผนก)</div></div>
        <div class="stat-card"><div class="label">แผนกที่มีพนักงาน</div><div class="value" id="ds-active" style="color:#F47920;">—</div><div class="sub">แผนก</div></div>
      </div>

      <div class="card">
        <div class="card-header">
          <div class="card-title">รายการแผนก</div>
          <div class="search-box">
            <svg width="14" height="14" fill="none" stroke="#9ca3af" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="dept-search" placeholder="ค้นหาชื่อแผนก..." oninput="filterDepartments()">
          </div>
          <button class="btn btn-primary" onclick="openDeptModal()">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            เพิ่มแผนก
          </button>
        </div>
        <div style="overflow-x:auto;">
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>ชื่อแผนก</th>
                <th>คำอธิบาย</th>
                <th>จำนวนพนักงาน</th>
                <th>สถานะ</th>
                <th>จัดการ</th>
              </tr>
            </thead>
            <tbody id="dept-tbody">
              <tr><td colspan="6" class="no-data">กำลังโหลด...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Employee list panel (expand on dept click) -->
      <div class="card" id="dept-detail-panel" style="display:none;margin-top:16px;">
        <div class="card-header">
          <div class="card-title" id="dept-detail-title">พนักงานในแผนก</div>
          <button class="btn btn-ghost btn-sm" onclick="closeDeptDetail()">✕ ปิด</button>
        </div>
        <div style="overflow-x:auto;">
          <table>
            <thead>
              <tr><th>รหัส</th><th>ชื่อ</th><th>Role</th><th>อีเมล</th><th>LINE</th></tr>
            </thead>
            <tbody id="dept-detail-tbody">
              <tr><td colspan="5" class="no-data">กำลังโหลด...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ==================== ATTENDANCE PAGE ==================== -->
    <div class="page" id="page-attendance">
      <div class="leave-summary-grid" style="grid-template-columns:repeat(4,1fr);">
        <div class="leave-sum-card"><div class="num" id="att-total"   style="color:#1357B0;">—</div><div class="lbl">รายการทั้งหมด</div></div>
        <div class="leave-sum-card"><div class="num" id="att-in"      style="color:#22c55e;">—</div><div class="lbl">เช็คอินแล้ว</div></div>
        <div class="leave-sum-card"><div class="num" id="att-out"     style="color:#F47920;">—</div><div class="lbl">เช็คเอาท์แล้ว</div></div>
        <div class="leave-sum-card"><div class="num" id="att-outside" style="color:#ef4444;">—</div><div class="lbl">นอกรัศมี</div></div>
      </div>

      <div class="card">
        <div class="card-header">
          <div class="card-title">บันทึกการเข้างาน</div>
          <input type="date" class="filter" id="att-date" onchange="loadAttendance()" style="padding:6px 10px;">
          <select class="filter" id="att-dept" onchange="loadAttendance()">
            <option value="">ทุกแผนก</option>
          </select>
          <div class="search-box">
            <svg width="14" height="14" fill="none" stroke="#9ca3af" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="att-search" placeholder="ค้นหาชื่อ / รหัส..." oninput="filterAttendance()">
