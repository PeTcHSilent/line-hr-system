      : `<span style="font-size:11px;color:#9ca3af;">—</span>`;
    return `<tr>
      <td style="color:#9ca3af;font-size:12px;">#${r.id}</td>
      <td><div class="emp-info">
        <div class="emp-avatar" style="width:28px;height:28px;font-size:11px;">${initials}</div>
        <div><div class="emp-name">${r.employee_name}</div><div class="emp-code">${r.employee_code || ''}</div></div>
