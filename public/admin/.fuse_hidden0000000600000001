async function loadCalendar() {
  const year  = document.getElementById('cal-year').value;
  const month = document.getElementById('cal-month').value;
  const calBody = document.getElementById('cal-body');
  calBody.innerHTML = '<div style="grid-column:1/-1;padding:20px;text-align:center;color:#9ca3af;">กำลังโหลด...</div>';

  try {
    const res = await fetch(`${API}/api/report/calendar?year=${year}&month=${month}`);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const { holidays, leaves } = await res.json();

    // Build holiday map: date string -> name
    const holMap = {};
    (holidays||[]).forEach(h => { holMap[h.date.slice(0,10)] = h.name; });

    // Build leave map: date string -> [employee names]
    const leaveMap = {};
    (leaves||[]).forEach(l => {
      const start = new Date(l.start_date);
      const end   = new Date(l.end_date);
      for (let d = new Date(start); d <= end; d.setDate(d.getDate()+1)) {
        const key = d.toISOString().slice(0,10);
        if (!leaveMap[key]) leaveMap[key] = [];
        leaveMap[key].push(`${l.employee_name} (${l.leave_type_name})`);
      }
    });

    const today  = new Date().toISOString().slice(0,10);
    const y = parseInt(year), m = parseInt(month);
    const firstDay = new Date(y, m-1, 1).getDay(); // 0=Sun
    const daysInMonth = new Date(y, m, 0).getDate();

    let cells = '';
    // Padding cells before first day
    for (let i = 0; i < firstDay; i++) {
      cells += '<div class="cal-cell other-month"></div>';
    }
    for (let day = 1; day <= daysInMonth; day++) {
      const dateStr = `${y}-${String(m).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
      const dow = new Date(y, m-1, day).getDay();
      const isWeekend  = dow === 0 || dow === 6;
      const isToday    = dateStr === today;
      const holName    = holMap[dateStr];
      const leaveList  = leaveMap[dateStr] || [];
      const cls = ['cal-cell', isToday?'today':'', isWeekend&&!isToday?'weekend':''].filter(Boolean).join(' ');

      cells += `<div class="${cls}">
        <div class="cal-date" style="color:${isWeekend||holName?'#ef4444':'#374151'}">${day}</div>
        ${holName ? `<div class="cal-holiday" title="${holName}">${holName}</div>` : ''}
        ${leaveList.slice(0,2).map(n=>`<div class="cal-leave" title="${n}">${n.split('(')[0].trim()}</div>`).join('')}
        ${leaveList.length > 2 ? `<div style="font-size:9px;color:#9ca3af;">+${leaveList.length-2} more</div>` : ''}
      </div>`;
    }
    calBody.innerHTML = cells;
  } catch(err) {
    calBody.innerHTML = `<div style="grid-column:1/-1;padding:20px;text-align:center;color:#ef4444;">${err.message}</div>`;
  }
}

// ---- INIT ----
async function init() {
  // โหลด departments ก่อน แล้วค่อยโหลด employees เพื่อให้ dropdown แผนกครบ
  try {
    const dRes = await fetch(`${API}/api/department`);
    if (dRes.ok) {
      const json = await dRes.json();
      allDeptData = Array.isArray(json) ? json : (json.departments || json.data || []);
      allDepts = allDeptData.map(d => ({ id: d.id, name: d.name }));
    }
  } catch(e) { allDepts = []; }

  const eRes = await fetch(`${API}/api/employee/`);
  allEmployees = await eRes.json();
  renderTable(allEmployees);
  updateStats(allEmployees);
  populateDeptFilter();
  populateManagerSelect();
  populateDeptModalSelect();
}
init();
</script>
</body>
