# ============================================
# LINE Messaging API
# ============================================
# จาก LINE Developers Console > Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# ============================================
# Database (PostgreSQL)
# ============================================
# Local: postgresql://user:password@localhost:5432/hr_db
# Production (Railway/Supabase): ใช้ Connection String จาก dashboard
DATABASE_URL=postgresql://postgres:password@localhost:5432/hr_db

# ============================================
# LIFF App
# ============================================
# จาก LINE Developers Console > LIFF > Add (สร้าง LIFF app แยกสำหรับแต่ละ endpoint)
LIFF_ID=your_liff_id_for_leave            # endpoint: /liff/leave
LIFF_ID_OT=your_liff_id_for_ot           # endpoint: /liff/ot
LIFF_ID_PAYSLIP=your_liff_id_for_payslip # endpoint: /liff/payslip
LIFF_ID_CHECKIN=your_liff_id_for_checkin # endpoint: /liff/checkin
LIFF_ID_HISTORY=your_liff_id_for_history # endpoint: /liff/history
LIFF_ID_PROFILE=your_liff_id_for_profile # endpoint: /liff/profile

# ============================================
# Server
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# Email Notification
# ============================================
# EMAIL_PROVIDER: gmail | outlook | smtp (default)
EMAIL_PROVIDER=gmail

# ชื่อผู้ส่งที่จะแสดงใน inbox
EMAIL_FROM_NAME=ต่อกัน HR

# Gmail: ใช้ App Password (ไม่ใช่รหัส Google ปกติ)
# สร้างที่: myaccount.google.com > Security > App passwords
EMAIL_USER=hr@togkun.com
EMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Outlook / Office 365
# EMAIL_USER=hr@togkun.com
# EMAIL_PASSWORD=your_password

# SMTP ทั่วไป
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_USER=hr@togkun.com
# EMAIL_PASSWORD=your_password

# ============================================
# GPS / Clock-In Office Location
# ============================================
# พิกัดออฟฟิศ — เปิด Google Maps คลิกขวา "What's here?" เพื่อดูพิกัด
OFFICE_LAT=13.7563
OFFICE_LNG=100.5018
# รัศมีอนุญาต (เมตร) — 200-500 เมตรแนะนำ
OFFICE_RADIUS_METERS=300

# ============================================
# Admin Dashboard (Optional)
# ============================================
ADMIN_SECRET_KEY=change_this_secret_key
